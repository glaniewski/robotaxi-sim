---
interface Props {
  caption?: string;
  source?: string;
  wide?: boolean;
  extraWide?: boolean;
}
const { caption, source, wide = false, extraWide = false } = Astro.props;
---

<figure class={`my-8${extraWide ? " figure-extra-wide" : wide ? " figure-wide" : ""}`}>
  <div class="rounded-lg border border-[color:var(--color-rule)] bg-white p-3 md:p-5">
    <slot />
  </div>
  {caption || source ? (
    <figcaption class="mt-2 text-xs md:text-sm text-[color:var(--color-muted)] leading-snug">
      {caption ? <span>{caption}</span> : null}
      {caption && source ? <span class="mx-1.5">·</span> : null}
      {source ? <span class="font-mono text-[0.7rem] opacity-80">{source}</span> : null}
    </figcaption>
  ) : null}
</figure>
